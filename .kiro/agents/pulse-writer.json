{
  "name": "writer",
  "description": "Specialized writing agent for PULSE timeline",
  "prompt": "file://../../timeline-pulse/.kiro/prompts/writer-prompt.md",
  "mcpServers": {
    "echoes": {
      "command": "npx",
      "args": ["-y", "@echoes-io/mcp-server@latest", "serve"],
      "env": {
        "ECHOES_EMBEDDING_DTYPE": "q4",
        "ECHOES_EMBEDDING_MODEL": "onnx-community/embeddinggemma-300m-ONNX",
        "ECHOES_GEMINI_MODEL": "gemini-3-flash-preview"
      }
    }
  },
  "tools": [
    "read",
    "write",
    "shell",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "use_subagent",
    "@echoes"
  ],
  "toolAliases": {},
  "allowedTools": [
    "read",
    "shell",
    "web_search",
    "web_fetch",
    "introspect",
    "thinking",
    "use_subagent",
    "@echoes"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "content/**",
        "docs/**",
        ".kiro/**",
        "*.md",
        "*.json"
      ]
    },
    "shell": {
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": ["pulse-character-checker", "pulse-continuity-checker", "pulse-style-checker", "pulse-structure-checker"],
      "trustedAgents": ["pulse-character-checker", "pulse-continuity-checker", "pulse-style-checker", "pulse-structure-checker"]
    }
  },
  "resources": [
    "file://../steering/steering-core.md",
    "skill://../skills/**/SKILL.md",
    "file://../../timeline-pulse/docs/pulse-structure.md",
    "file://../../timeline-pulse/docs/characters/*.md",
    "file://../../timeline-pulse/.kiro/specs/**/*.md",
    "file://../../resonance/output/nic-continuity-bible.md",
    "file://../../resonance/output/anti-ai-voice-guide-en.md",
    "file://../../resonance/output/architettura-echi-paralleli.md",
    "file://../../timeline-eros/docs/characters/cri/cri.md",
    "file://../../timeline-eros/docs/characters/ele/ele.md",
    "file://../../timeline-eros/docs/characters/ele/dani.md",
    "file://../../timeline-eros/docs/characters/ale/ale.md"
  ]
}
